namespace Example

type WithRepeated = { Tags: string list; Scores: int list }

module WithRepeated =
    let empty = { Tags = []; Scores = [] }

    let computeSize (value: WithRepeated) : int =
        let mutable size = 0
        value.Tags |> List.iter (fun item -> size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(item))

        if not (List.isEmpty value.Scores) then
            let mutable packedSize = 0
            value.Scores |> List.iter (fun item -> packedSize <- packedSize + Google.Protobuf.CodedOutputStream.ComputeInt32Size(item))
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeLengthSize(packedSize) + packedSize

        size

    let writeTo (output: Google.Protobuf.CodedOutputStream) (value: WithRepeated) : unit =
        value.Tags |> List.iter (fun item -> output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteString(item))

        if not (List.isEmpty value.Scores) then
            let mutable packedSize = 0
            value.Scores |> List.iter (fun item -> packedSize <- packedSize + Google.Protobuf.CodedOutputStream.ComputeInt32Size(item))
            output.WriteTag(2, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteLength(packedSize)
            value.Scores |> List.iter (fun item -> output.WriteInt32(item))

    let encode (value: WithRepeated) : byte array =
        let size = computeSize value

        if size = 0 then
            Array.empty
        else
            let buffer = Array.zeroCreate size
            use output = new Google.Protobuf.CodedOutputStream(buffer)
            writeTo output value
            output.Flush()
            buffer

    let decodeFrom (input: Google.Protobuf.CodedInputStream) : WithRepeated =
        let mutable _Tags = []
        let mutable _Scores = []
        let mutable tag = input.ReadTag()

        while tag <> 0u do
            match Google.Protobuf.WireFormat.GetTagFieldNumber(tag) with
            | 1 -> _Tags <- input.ReadString() :: _Tags
            | 2 ->
                let wt = Google.Protobuf.WireFormat.GetTagWireType(tag)

                if wt = Google.Protobuf.WireFormat.WireType.LengthDelimited then
                    use packedInput = input.ReadBytes().CreateCodedInput()

                    while not packedInput.IsAtEnd do
                        _Scores <- packedInput.ReadInt32() :: _Scores
                else
                    _Scores <- input.ReadInt32() :: _Scores
            | _ -> input.SkipLastField()

            tag <- input.ReadTag()

        { Tags = List.rev _Tags
          Scores = List.rev _Scores }

    let decode (data: byte array) : WithRepeated =
        use input = new Google.Protobuf.CodedInputStream(data)
        decodeFrom input

    let writeJsonTo (writer: System.Text.Json.Utf8JsonWriter) (value: WithRepeated) : unit =
        writer.WriteStartObject()

        if not (List.isEmpty value.Tags) then
            writer.WriteStartArray("tags")

            for item in value.Tags do
                writer.WriteStringValue(item)

            writer.WriteEndArray()

        if not (List.isEmpty value.Scores) then
            writer.WriteStartArray("scores")

            for item in value.Scores do
                writer.WriteNumberValue(item)

            writer.WriteEndArray()

        writer.WriteEndObject()

    let encodeJson (value: WithRepeated) : string =
        use bufferWriter = new System.IO.MemoryStream()
        use writer = new System.Text.Json.Utf8JsonWriter(bufferWriter)
        writeJsonTo writer value
        writer.Flush()
        System.Text.Encoding.UTF8.GetString(bufferWriter.ToArray())

    let decodeJsonElement (element: System.Text.Json.JsonElement) : WithRepeated =
        let mutable _Tags = []
        let mutable _Scores = []

        for prop in element.EnumerateObject() do
            match prop.Name with
            | "tags" ->
                for item in prop.Value.EnumerateArray() do
                    _Tags <- item.GetString() :: _Tags
            | "scores" ->
                for item in prop.Value.EnumerateArray() do
                    _Scores <- item.GetInt32() :: _Scores
            | _ -> ()

        { Tags = List.rev _Tags
          Scores = List.rev _Scores }

    let decodeJson (json: string) : WithRepeated =
        use doc = System.Text.Json.JsonDocument.Parse(json)
        decodeJsonElement doc.RootElement
