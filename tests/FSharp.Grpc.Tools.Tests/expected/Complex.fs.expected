            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeLengthSize(subSize) + subSize
        | None -> ()

        value.DomainNames |> List.iter (fun item -> size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(3) + Google.Protobuf.CodedOutputStream.ComputeStringSize(item))
        value.Metadata |> Map.iter (fun mapKey mapValue -> let entrySize = Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(mapKey) + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeStringSize(mapValue) in size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(4) + Google.Protobuf.CodedOutputStream.ComputeLengthSize(entrySize) + entrySize)
        value.Departments |> List.iter (fun item -> let subSize = Department.computeSize item in size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(5) + Google.Protobuf.CodedOutputStream.ComputeLengthSize(subSize) + subSize)
        size

    let writeTo (output: Google.Protobuf.CodedOutputStream) (value: Organization) : unit =
        if value.Name <> "" then
            output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(value.Name)

        match value.BillingAddress with
        | Some v ->
            let subSize = Address.computeSize v
            output.WriteTag(2, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteLength(subSize)
            Address.writeTo output v
        | None -> ()

        value.DomainNames |> List.iter (fun item -> output.WriteTag(3, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteString(item))
        value.Metadata |> Map.iter (fun mapKey mapValue -> let entrySize = Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(mapKey) + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeStringSize(mapValue) in output.WriteTag(4, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteLength(entrySize); output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteString(mapKey); output.WriteTag(2, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteString(mapValue))
        value.Departments |> List.iter (fun item -> let subSize = Department.computeSize item in output.WriteTag(5, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteLength(subSize); Department.writeTo output item)

    let encode (value: Organization) : byte array =
        let size = computeSize value

        if size = 0 then
            Array.empty
        else
            let buffer = Array.zeroCreate size
            use output = new Google.Protobuf.CodedOutputStream(buffer)
            writeTo output value
            output.Flush()
            buffer

    let decodeFrom (input: Google.Protobuf.CodedInputStream) : Organization =
        let mutable _Name = ""
        let mutable _BillingAddress = None
        let mutable _DomainNames = []
        let mutable _Metadata = Map.empty
        let mutable _Departments = []
        let mutable tag = input.ReadTag()

        while tag <> 0u do
            match Google.Protobuf.WireFormat.GetTagFieldNumber(tag) with
            | 1 -> _Name <- input.ReadString()
            | 2 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _BillingAddress <- Some(Address.decodeFrom subInput)
            | 3 -> _DomainNames <- input.ReadString() :: _DomainNames
            | 4 ->
                use entryInput = input.ReadBytes().CreateCodedInput()
                let mutable key = ""
                let mutable mapValue = ""
                let mutable entryTag = entryInput.ReadTag()

                while entryTag <> 0u do
                    match Google.Protobuf.WireFormat.GetTagFieldNumber(entryTag) with
                    | 1 -> key <- entryInput.ReadString()
                    | 2 -> mapValue <- entryInput.ReadString()
                    | _ -> entryInput.SkipLastField()

                    entryTag <- entryInput.ReadTag()

                _Metadata <- Map.add key mapValue _Metadata
            | 5 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _Departments <- Department.decodeFrom subInput :: _Departments
            | _ -> input.SkipLastField()

            tag <- input.ReadTag()

        { Name = _Name
          BillingAddress = _BillingAddress
          DomainNames = List.rev _DomainNames
          Metadata = _Metadata
          Departments = List.rev _Departments }

    let decode (data: byte array) : Organization =
        use input = new Google.Protobuf.CodedInputStream(data)
        decodeFrom input

    let writeJsonTo (writer: System.Text.Json.Utf8JsonWriter) (value: Organization) : unit =
        writer.WriteStartObject()

        if value.Name <> "" then
            writer.WriteString("name", value.Name)

        match value.BillingAddress with
        | Some v ->
            writer.WritePropertyName("billingAddress")
            Address.writeJsonTo writer v
        | None -> ()

        if not (List.isEmpty value.DomainNames) then
            writer.WriteStartArray("domainNames")

            for item in value.DomainNames do
                writer.WriteStringValue(item)

            writer.WriteEndArray()

        if not (Map.isEmpty value.Metadata) then
            writer.WriteStartObject("metadata")

            for kvp in value.Metadata do
                writer.WritePropertyName(string kvp.Key)
                writer.WriteStringValue(kvp.Value)

            writer.WriteEndObject()

        if not (List.isEmpty value.Departments) then
            writer.WriteStartArray("departments")

            for item in value.Departments do
                Department.writeJsonTo writer item

            writer.WriteEndArray()

        writer.WriteEndObject()

    let encodeJson (value: Organization) : string =
        use bufferWriter = new System.IO.MemoryStream()
        use writer = new System.Text.Json.Utf8JsonWriter(bufferWriter)
        writeJsonTo writer value
        writer.Flush()
        System.Text.Encoding.UTF8.GetString(bufferWriter.ToArray())

    let decodeJsonElement (element: System.Text.Json.JsonElement) : Organization =
        let mutable _Name = ""
        let mutable _BillingAddress = None
        let mutable _DomainNames = []
        let mutable _Metadata = Map.empty
        let mutable _Departments = []

        for prop in element.EnumerateObject() do
            match prop.Name with
            | "name" -> _Name <- prop.Value.GetString()
            | "billingAddress" -> _BillingAddress <- Some(Address.decodeJsonElement prop.Value)
            | "billing_address" -> _BillingAddress <- Some(Address.decodeJsonElement prop.Value)
            | "domainNames" ->
                for item in prop.Value.EnumerateArray() do
                    _DomainNames <- item.GetString() :: _DomainNames
            | "domain_names" ->
                for item in prop.Value.EnumerateArray() do
                    _DomainNames <- item.GetString() :: _DomainNames
            | "metadata" ->
                for entry in prop.Value.EnumerateObject() do
                    _Metadata <- Map.add (entry.Name) (entry.Value.GetString()) _Metadata
            | "departments" ->
                for item in prop.Value.EnumerateArray() do
                    _Departments <- Department.decodeJsonElement item :: _Departments
            | _ -> ()

        { Name = _Name
          BillingAddress = _BillingAddress
          DomainNames = List.rev _DomainNames
          Metadata = _Metadata
          Departments = List.rev _Departments }

    let decodeJson (json: string) : Organization =
        use doc = System.Text.Json.JsonDocument.Parse(json)
        decodeJsonElement doc.RootElement

type UserContact =
    | PhoneNumber of phoneNumber: string
    | SlackHandle of slackHandle: string

type User =
    { Id: string
      DisplayName: string
      Email: string
      Status: UserStatus
      HomeAddress: Address option
      OtherAddresses: Address list
      Scores: Map<string, int>
      Rating: float option
      Organization: Organization option
      Contact: UserContact option
      Manager: User option }

module User =
    let empty =
        { Id = ""
          DisplayName = ""
          Email = ""
          Status = LanguagePrimitives.EnumOfValue 0
          HomeAddress = None
          OtherAddresses = []
          Scores = Map.empty
          Rating = None
          Organization = None
          Contact = None
          Manager = None }

    let computeSize (value: User) : int =
