namespace Acme.Platform.V1

type UserStatus =
    | UserStatusUnknown = 0
    | UserStatusActive = 1
    | UserStatusSuspended = 2

module UserStatus =
    let toJsonName (value: UserStatus) : string =
        match value with
        | UserStatus.UserStatusUnknown -> "USER_STATUS_UNKNOWN"
        | UserStatus.UserStatusActive -> "USER_STATUS_ACTIVE"
        | UserStatus.UserStatusSuspended -> "USER_STATUS_SUSPENDED"
        | _ -> string (int value)

    let fromJsonName (name: string) : UserStatus =
        match name with
        | "USER_STATUS_UNKNOWN" -> UserStatus.UserStatusUnknown
        | "USER_STATUS_ACTIVE" -> UserStatus.UserStatusActive
        | "USER_STATUS_SUSPENDED" -> UserStatus.UserStatusSuspended
        | _ ->
            match System.Int32.TryParse(name) with | true, v -> LanguagePrimitives.EnumOfValue v | _ -> LanguagePrimitives.EnumOfValue 0

type Address =
    { Street: string
      City: string
      CountryCode: string
      ZipCode: string option }

module Address =
    let empty =
        { Street = ""
          City = ""
          CountryCode = ""
          ZipCode = None }

    let computeSize (value: Address) : int =
        let mutable size = 0

        if value.Street <> "" then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(value.Street)

        if value.City <> "" then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeStringSize(value.City)

        if value.CountryCode <> "" then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(3) + Google.Protobuf.CodedOutputStream.ComputeStringSize(value.CountryCode)

        match value.ZipCode with
        | Some v ->
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(4) + Google.Protobuf.CodedOutputStream.ComputeStringSize(v)
        | None -> ()

        size

    let writeTo (output: Google.Protobuf.CodedOutputStream) (value: Address) : unit =
        if value.Street <> "" then
            output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(value.Street)

        if value.City <> "" then
            output.WriteTag(2, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(value.City)

        if value.CountryCode <> "" then
            output.WriteTag(3, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(value.CountryCode)

        match value.ZipCode with
        | Some v ->
            output.WriteTag(4, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(v)
        | None -> ()

    let encode (value: Address) : byte array =
        let size = computeSize value

        if size = 0 then
            Array.empty
        else
            let buffer = Array.zeroCreate size
            use output = new Google.Protobuf.CodedOutputStream(buffer)
            writeTo output value
            output.Flush()
            buffer

    let decodeFrom (input: Google.Protobuf.CodedInputStream) : Address =
        let mutable _Street = ""
        let mutable _City = ""
        let mutable _CountryCode = ""
        let mutable _ZipCode = None
        let mutable tag = input.ReadTag()

        while tag <> 0u do
            match Google.Protobuf.WireFormat.GetTagFieldNumber(tag) with
            | 1 -> _Street <- input.ReadString()
            | 2 -> _City <- input.ReadString()
            | 3 -> _CountryCode <- input.ReadString()
            | 4 -> _ZipCode <- Some(input.ReadString())
            | _ -> input.SkipLastField()

            tag <- input.ReadTag()

        { Street = _Street
          City = _City
          CountryCode = _CountryCode
          ZipCode = _ZipCode }

    let decode (data: byte array) : Address =
        use input = new Google.Protobuf.CodedInputStream(data)
        decodeFrom input

    let writeJsonTo (writer: System.Text.Json.Utf8JsonWriter) (value: Address) : unit =
        writer.WriteStartObject()

        if value.Street <> "" then
            writer.WriteString("street", value.Street)

        if value.City <> "" then
            writer.WriteString("city", value.City)

        if value.CountryCode <> "" then
            writer.WriteString("countryCode", value.CountryCode)

        match value.ZipCode with
        | Some v -> writer.WriteString("zipCode", v)
        | None -> ()

        writer.WriteEndObject()

    let encodeJson (value: Address) : string =
        use bufferWriter = new System.IO.MemoryStream()
        use writer = new System.Text.Json.Utf8JsonWriter(bufferWriter)
        writeJsonTo writer value
        writer.Flush()
        System.Text.Encoding.UTF8.GetString(bufferWriter.ToArray())

    let decodeJsonElement (element: System.Text.Json.JsonElement) : Address =
        let mutable _Street = ""
        let mutable _City = ""
        let mutable _CountryCode = ""
        let mutable _ZipCode = None

        for prop in element.EnumerateObject() do
            match prop.Name with
            | "street" -> _Street <- prop.Value.GetString()
            | "city" -> _City <- prop.Value.GetString()
            | "countryCode" -> _CountryCode <- prop.Value.GetString()
            | "country_code" -> _CountryCode <- prop.Value.GetString()
            | "zipCode" -> _ZipCode <- Some(prop.Value.GetString())
            | "zip_code" -> _ZipCode <- Some(prop.Value.GetString())
            | _ -> ()

        { Street = _Street
          City = _City
          CountryCode = _CountryCode
          ZipCode = _ZipCode }

    let decodeJson (json: string) : Address =
        use doc = System.Text.Json.JsonDocument.Parse(json)
        decodeJsonElement doc.RootElement

type Priority =
    | PriorityUnspecified = 0
    | PriorityLow = 1
    | PriorityHigh = 2

module Priority =
    let toJsonName (value: Priority) : string =
        match value with
        | Priority.PriorityUnspecified -> "PRIORITY_UNSPECIFIED"
        | Priority.PriorityLow -> "PRIORITY_LOW"
        | Priority.PriorityHigh -> "PRIORITY_HIGH"
        | _ -> string (int value)

    let fromJsonName (name: string) : Priority =
        match name with
        | "PRIORITY_UNSPECIFIED" -> Priority.PriorityUnspecified
        | "PRIORITY_LOW" -> Priority.PriorityLow
        | "PRIORITY_HIGH" -> Priority.PriorityHigh
        | _ ->
            match System.Int32.TryParse(name) with | true, v -> LanguagePrimitives.EnumOfValue v | _ -> LanguagePrimitives.EnumOfValue 0

type Department =
    { Name: string
      Members: User list
      Priority: Priority }

module Department =
    let empty =
        { Name = ""
          Members = []
          Priority = LanguagePrimitives.EnumOfValue 0 }

    let computeSize (value: Department) : int =
        let mutable size = 0

        if value.Name <> "" then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(value.Name)

        value.Members |> List.iter (fun item -> let subSize = User.computeSize item in size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeLengthSize(subSize) + subSize)

        if int value.Priority <> 0 then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(3) + Google.Protobuf.CodedOutputStream.ComputeInt32Size(int value.Priority)

        size

    let writeTo (output: Google.Protobuf.CodedOutputStream) (value: Department) : unit =
        if value.Name <> "" then
            output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteString(value.Name)

        value.Members |> List.iter (fun item -> let subSize = User.computeSize item in output.WriteTag(2, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteLength(subSize); User.writeTo output item)

        if int value.Priority <> 0 then
            output.WriteTag(3, Google.Protobuf.WireFormat.WireType.Varint)
            output.WriteInt32(int value.Priority)

    let encode (value: Department) : byte array =
        let size = computeSize value

        if size = 0 then
            Array.empty
        else
            let buffer = Array.zeroCreate size
            use output = new Google.Protobuf.CodedOutputStream(buffer)
            writeTo output value
            output.Flush()
            buffer

    let decodeFrom (input: Google.Protobuf.CodedInputStream) : Department =
        let mutable _Name = ""
        let mutable _Members = []
        let mutable _Priority = LanguagePrimitives.EnumOfValue 0
        let mutable tag = input.ReadTag()

        while tag <> 0u do
            match Google.Protobuf.WireFormat.GetTagFieldNumber(tag) with
            | 1 -> _Name <- input.ReadString()
            | 2 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _Members <- User.decodeFrom subInput :: _Members
            | 3 -> _Priority <- LanguagePrimitives.EnumOfValue(input.ReadInt32())
            | _ -> input.SkipLastField()

            tag <- input.ReadTag()

        { Name = _Name
          Members = List.rev _Members
          Priority = _Priority }

    let decode (data: byte array) : Department =
        use input = new Google.Protobuf.CodedInputStream(data)
        decodeFrom input

    let writeJsonTo (writer: System.Text.Json.Utf8JsonWriter) (value: Department) : unit =
        writer.WriteStartObject()

        if value.Name <> "" then
            writer.WriteString("name", value.Name)

        if not (List.isEmpty value.Members) then
            writer.WriteStartArray("members")

            for item in value.Members do
                User.writeJsonTo writer item

            writer.WriteEndArray()

        if int value.Priority <> 0 then
            writer.WriteString("priority", Priority.toJsonName value.Priority)

        writer.WriteEndObject()

    let encodeJson (value: Department) : string =
        use bufferWriter = new System.IO.MemoryStream()
        use writer = new System.Text.Json.Utf8JsonWriter(bufferWriter)
        writeJsonTo writer value
        writer.Flush()
        System.Text.Encoding.UTF8.GetString(bufferWriter.ToArray())

    let decodeJsonElement (element: System.Text.Json.JsonElement) : Department =
        let mutable _Name = ""
        let mutable _Members = []
        let mutable _Priority = LanguagePrimitives.EnumOfValue 0

        for prop in element.EnumerateObject() do
            match prop.Name with
            | "name" -> _Name <- prop.Value.GetString()
            | "members" ->
                for item in prop.Value.EnumerateArray() do
                    _Members <- User.decodeJsonElement item :: _Members
            | "priority" ->
                _Priority <-
                    Priority.fromJsonName(if prop.Value.ValueKind = System.Text.Json.JsonValueKind.Number then string (prop.Value.GetInt32()) else prop.Value.GetString())
            | _ -> ()

        { Name = _Name
          Members = List.rev _Members
          Priority = _Priority }

    let decodeJson (json: string) : Department =
        use doc = System.Text.Json.JsonDocument.Parse(json)
        decodeJsonElement doc.RootElement

type Organization =
    { Name: string
      BillingAddress: Address option
      DomainNames: string list
      Metadata: Map<string, string>
      Departments: Department list }

module Organization =
    let empty =
        { Name = ""
          BillingAddress = None
          DomainNames = []
          Metadata = Map.empty
          Departments = [] }

    let computeSize (value: Organization) : int =
        let mutable size = 0

        if value.Name <> "" then
            size <- size + Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(value.Name)

