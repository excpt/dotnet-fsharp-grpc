        value.Scores |> Map.iter (fun mapKey mapValue -> let entrySize = Google.Protobuf.CodedOutputStream.ComputeTagSize(1) + Google.Protobuf.CodedOutputStream.ComputeStringSize(mapKey) + Google.Protobuf.CodedOutputStream.ComputeTagSize(2) + Google.Protobuf.CodedOutputStream.ComputeInt32Size(mapValue) in output.WriteTag(7, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteLength(entrySize); output.WriteTag(1, Google.Protobuf.WireFormat.WireType.LengthDelimited); output.WriteString(mapKey); output.WriteTag(2, Google.Protobuf.WireFormat.WireType.Varint); output.WriteInt32(mapValue))

        match value.Rating with
        | Some v ->
            output.WriteTag(8, Google.Protobuf.WireFormat.WireType.Fixed64)
            output.WriteDouble(v)
        | None -> ()

        match value.Organization with
        | Some v ->
            let subSize = Organization.computeSize v
            output.WriteTag(9, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteLength(subSize)
            Organization.writeTo output v
        | None -> ()

        match value.Contact with
        | Some oneofValue ->
            match oneofValue with
            | UserContact.PhoneNumber v ->
                output.WriteTag(10, Google.Protobuf.WireFormat.WireType.LengthDelimited)
                output.WriteString(v)
            | UserContact.SlackHandle v ->
                output.WriteTag(11, Google.Protobuf.WireFormat.WireType.LengthDelimited)
                output.WriteString(v)
        | None -> ()

        match value.Manager with
        | Some v ->
            let subSize = User.computeSize v
            output.WriteTag(12, Google.Protobuf.WireFormat.WireType.LengthDelimited)
            output.WriteLength(subSize)
            User.writeTo output v
