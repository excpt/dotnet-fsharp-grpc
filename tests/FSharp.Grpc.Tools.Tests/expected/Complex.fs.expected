        let mutable _DisplayName = ""
        let mutable _Email = ""
        let mutable _Status = LanguagePrimitives.EnumOfValue 0
        let mutable _HomeAddress = None
        let mutable _OtherAddresses = []
        let mutable _Scores = Map.empty
        let mutable _Rating = None
        let mutable _Organization = None
        let mutable _Contact = None
        let mutable _Manager = None
        let mutable tag = input.ReadTag()

        while tag <> 0u do
            match Google.Protobuf.WireFormat.GetTagFieldNumber(tag) with
            | 1 -> _Id <- input.ReadString()
            | 2 -> _DisplayName <- input.ReadString()
            | 3 -> _Email <- input.ReadString()
            | 4 -> _Status <- LanguagePrimitives.EnumOfValue(input.ReadInt32())
            | 5 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _HomeAddress <- Some(Address.decodeFrom subInput)
            | 6 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _OtherAddresses <- Address.decodeFrom subInput :: _OtherAddresses
            | 7 ->
                use entryInput = input.ReadBytes().CreateCodedInput()
                let mutable key = ""
                let mutable mapValue = 0
                let mutable entryTag = entryInput.ReadTag()

                while entryTag <> 0u do
                    match Google.Protobuf.WireFormat.GetTagFieldNumber(entryTag) with
                    | 1 -> key <- entryInput.ReadString()
                    | 2 -> mapValue <- entryInput.ReadInt32()
                    | _ -> entryInput.SkipLastField()

                    entryTag <- entryInput.ReadTag()

                _Scores <- Map.add key mapValue _Scores
            | 8 -> _Rating <- Some(input.ReadDouble())
            | 9 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _Organization <- Some(Organization.decodeFrom subInput)
            | 10 -> _Contact <- Some(UserContact.PhoneNumber(input.ReadString()))
            | 11 -> _Contact <- Some(UserContact.SlackHandle(input.ReadString()))
            | 12 ->
                use subInput = input.ReadBytes().CreateCodedInput()
                _Manager <- Some(User.decodeFrom subInput)
            | _ -> input.SkipLastField()

            tag <- input.ReadTag()

        { Id = _Id
          DisplayName = _DisplayName
          Email = _Email
          Status = _Status
          HomeAddress = _HomeAddress
          OtherAddresses = List.rev _OtherAddresses
          Scores = _Scores
          Rating = _Rating
          Organization = _Organization
          Contact = _Contact
          Manager = _Manager }

    let decode (data: byte array) : User =
        use input = new Google.Protobuf.CodedInputStream(data)
        decodeFrom input

    let writeJsonTo (writer: System.Text.Json.Utf8JsonWriter) (value: User) : unit =
        writer.WriteStartObject()

        if value.Id <> "" then
            writer.WriteString("id", value.Id)

        if value.DisplayName <> "" then
            writer.WriteString("displayName", value.DisplayName)

        if value.Email <> "" then
            writer.WriteString("email", value.Email)

        if int value.Status <> 0 then
            writer.WriteString("status", UserStatus.toJsonName value.Status)

        match value.HomeAddress with
        | Some v ->
            writer.WritePropertyName("homeAddress")
            Address.writeJsonTo writer v
        | None -> ()

        if not (List.isEmpty value.OtherAddresses) then
            writer.WriteStartArray("otherAddresses")

            for item in value.OtherAddresses do
                Address.writeJsonTo writer item

            writer.WriteEndArray()

        if not (Map.isEmpty value.Scores) then
            writer.WriteStartObject("scores")

            for kvp in value.Scores do
                writer.WritePropertyName(string kvp.Key)
                writer.WriteNumberValue(kvp.Value)

            writer.WriteEndObject()

        match value.Rating with
        | Some v ->
            if System.Double.IsNaN(v) then writer.WriteString("rating", "NaN") elif System.Double.IsPositiveInfinity(v) then writer.WriteString("rating", "Infinity") elif System.Double.IsNegativeInfinity(v) then writer.WriteString("rating", "-Infinity") else writer.WriteNumber("rating", v)
        | None -> ()

        match value.Organization with
        | Some v ->
            writer.WritePropertyName("organization")
            Organization.writeJsonTo writer v
        | None -> ()

        match value.Contact with
        | Some oneofValue ->
            match oneofValue with
            | UserContact.PhoneNumber v -> writer.WriteString("phoneNumber", v)
            | UserContact.SlackHandle v -> writer.WriteString("slackHandle", v)
        | None -> ()

        match value.Manager with
        | Some v ->
            writer.WritePropertyName("manager")
            User.writeJsonTo writer v
        | None -> ()

        writer.WriteEndObject()

    let encodeJson (value: User) : string =
        use bufferWriter = new System.IO.MemoryStream()
        use writer = new System.Text.Json.Utf8JsonWriter(bufferWriter)
        writeJsonTo writer value
        writer.Flush()
        System.Text.Encoding.UTF8.GetString(bufferWriter.ToArray())

    let decodeJsonElement (element: System.Text.Json.JsonElement) : User =
        let mutable _Id = ""
        let mutable _DisplayName = ""
        let mutable _Email = ""
        let mutable _Status = LanguagePrimitives.EnumOfValue 0
        let mutable _HomeAddress = None
        let mutable _OtherAddresses = []
        let mutable _Scores = Map.empty
        let mutable _Rating = None
        let mutable _Organization = None
        let mutable _Contact = None
        let mutable _Manager = None

        for prop in element.EnumerateObject() do
            match prop.Name with
            | "id" -> _Id <- prop.Value.GetString()
            | "displayName" -> _DisplayName <- prop.Value.GetString()
            | "display_name" -> _DisplayName <- prop.Value.GetString()
            | "email" -> _Email <- prop.Value.GetString()
            | "status" ->
                _Status <-
                    UserStatus.fromJsonName(if prop.Value.ValueKind = System.Text.Json.JsonValueKind.Number then string (prop.Value.GetInt32()) else prop.Value.GetString())
            | "homeAddress" -> _HomeAddress <- Some(Address.decodeJsonElement prop.Value)
            | "home_address" -> _HomeAddress <- Some(Address.decodeJsonElement prop.Value)
            | "otherAddresses" ->
                for item in prop.Value.EnumerateArray() do
                    _OtherAddresses <- Address.decodeJsonElement item :: _OtherAddresses
            | "other_addresses" ->
                for item in prop.Value.EnumerateArray() do
                    _OtherAddresses <- Address.decodeJsonElement item :: _OtherAddresses
            | "scores" ->
                for entry in prop.Value.EnumerateObject() do
                    _Scores <- Map.add (entry.Name) (entry.Value.GetInt32()) _Scores
            | "rating" ->
                _Rating <-
                    Some(if prop.Value.ValueKind = System.Text.Json.JsonValueKind.String then (match prop.Value.GetString() with | "NaN" -> System.Double.NaN | "Infinity" -> System.Double.PositiveInfinity | "-Infinity" -> System.Double.NegativeInfinity | s -> float s) else prop.Value.GetDouble())
            | "organization" -> _Organization <- Some(Organization.decodeJsonElement prop.Value)
            | "phoneNumber" -> _Contact <- Some(UserContact.PhoneNumber(prop.Value.GetString()))
            | "phone_number" -> _Contact <- Some(UserContact.PhoneNumber(prop.Value.GetString()))
            | "slackHandle" -> _Contact <- Some(UserContact.SlackHandle(prop.Value.GetString()))
            | "slack_handle" -> _Contact <- Some(UserContact.SlackHandle(prop.Value.GetString()))
            | "manager" -> _Manager <- Some(User.decodeJsonElement prop.Value)
            | _ -> ()

        { Id = _Id
          DisplayName = _DisplayName
          Email = _Email
          Status = _Status
          HomeAddress = _HomeAddress
          OtherAddresses = List.rev _OtherAddresses
          Scores = _Scores
          Rating = _Rating
          Organization = _Organization
          Contact = _Contact
          Manager = _Manager }

    let decodeJson (json: string) : User =
        use doc = System.Text.Json.JsonDocument.Parse(json)
        decodeJsonElement doc.RootElement
